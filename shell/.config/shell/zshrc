#!/bin/zsh
# =============================================================
#  ~/.config/shell/zshrc
#
#  Interactive zsh configuration.
#  Sourced by ~/.zshrc for every interactive zsh session.
# =============================================================


# =============================================================
#  Environment Bootstrap
# =============================================================

[ -z "$XDG_CONFIG_HOME" ] && \
    [ -f "$HOME/.config/shell/profile" ] && \
    . "$HOME/.config/shell/profile"


# =============================================================
#  Shared Config
# =============================================================

[ -f "$XDG_CONFIG_HOME/shell/aliases"   ] && . "$XDG_CONFIG_HOME/shell/aliases"
[ -f "$XDG_CONFIG_HOME/shell/functions" ] && . "$XDG_CONFIG_HOME/shell/functions"


# =============================================================
#  History
# =============================================================

export HISTFILE="$XDG_STATE_HOME/zsh/history"
HISTSIZE=10000
SAVEHIST=10000
mkdir -p "$(dirname "$HISTFILE")"

setopt HIST_IGNORE_DUPS         # don't record duplicates
setopt HIST_IGNORE_SPACE        # don't record lines starting with space
setopt HIST_EXPIRE_DUPS_FIRST   # expire dups first when trimming
setopt HIST_SAVE_NO_DUPS        # don't write duplicates to file
setopt SHARE_HISTORY            # share history between sessions
setopt EXTENDED_HISTORY         # record timestamp with each command


# =============================================================
#  Shell Options
# =============================================================

setopt AUTO_CD              # cd by typing directory name
setopt CORRECT              # suggest corrections for mistyped commands
setopt INTERACTIVE_COMMENTS # allow # comments in interactive shell
setopt NO_BEEP
unsetopt PROMPT_SP          # suppress the % on partial lines


# =============================================================
#  Completion
# =============================================================

autoload -Uz compinit

# Rebuild completion dump at most once per day
mkdir -p "$XDG_CACHE_HOME/zsh"
local _compdump="$XDG_CACHE_HOME/zsh/compdump"
if [[ -n $_compdump(#qN.mh+24) ]]; then
    compinit -d "$_compdump"
else
    compinit -C -d "$_compdump"
fi

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'        # case-insensitive
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"    # colored entries
zstyle ':completion:*' group-name ''                        # group by type
zstyle ':completion:*:descriptions' format '%F{yellow}── %d ──%f'


# =============================================================
#  Vi Mode
# =============================================================

bindkey -v
export KEYTIMEOUT=1     # 10ms delay for key sequences — faster ESC

# Cursor shape: beam (│) in insert, block (█) in normal mode
_cursor_beam()  { printf '\033[6 q'; }
_cursor_block() { printf '\033[2 q'; }

zle -N zle-line-init _cursor_beam
zle -N zle-keymap-select
zle-keymap-select() {
    [[ $KEYMAP == vicmd ]] && _cursor_block || _cursor_beam
}

# History search with arrows and j/k in normal mode
autoload -Uz up-line-or-beginning-search down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search
bindkey '^[[A'  up-line-or-beginning-search
bindkey '^[[B'  down-line-or-beginning-search
bindkey -M vicmd 'k' up-line-or-beginning-search
bindkey -M vicmd 'j' down-line-or-beginning-search

# Sane keys
bindkey '^[[3~' delete-char     # Delete
bindkey '^[[H'  beginning-of-line
bindkey '^[[F'  end-of-line
bindkey '^L'    clear-screen


# =============================================================
#  Prompt
#  [user@host] ~/path (branch*)
#  $
# =============================================================

autoload -Uz vcs_info
precmd() { vcs_info }

zstyle ':vcs_info:git:*' check-for-changes true
zstyle ':vcs_info:git:*' unstagedstr        '*'
zstyle ':vcs_info:git:*' formats            ' %F{yellow}(%b%u)%f'
zstyle ':vcs_info:git:*' actionformats      ' %F{red}(%b|%a)%f'

setopt PROMPT_SUBST
PROMPT='%F{240}[%F{green}%B%n%b%F{240}@%F{cyan}%B%m%b%F{240}]%f %F{blue}%B%~%b%f${vcs_info_msg_0_}
%F{yellow}%B%#%b%f '


# =============================================================
#  Pager
#  LESSOPEN set here (not profile) to avoid subprocesses at login.
# =============================================================

if command -v bat >/dev/null 2>&1; then
    export LESSOPEN="| bat --color=always --style=plain --paging=never %s 2>/dev/null"
    export MANPAGER="sh -c 'col -bx | bat --language=man --style=plain --color=always'"
    export MANROFFOPT="-c"
else
    export LESSOPEN="| highlight -O ansi %s 2>/dev/null"
fi


# =============================================================
#  Integrations
# =============================================================

# zoxide — smarter cd
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init zsh)"
