# ============================================================
#  Core Settings
# ============================================================

set shell sh
set shellopts '-eu -o pipefail'
set ifs "\n"

set icons  true
set drawbox true
set hidden false

set ignorecase true
set smartcase  true

set number         true
set relativenumber true

set mouse     true
set scrolloff 8

set period 2                    # stat refresh interval (seconds)

set ratios   1:2:3
set info     size:time

set preview  true
set previewer ~/.config/lf/scope.sh
set cleaner   ~/.config/lf/cleaner.sh

# Cursor highlight in preview pane
set cursorpreviewfmt "\033[7;2;33m"

# ============================================================
#  Prompt (dynamic — overridden by on-cd below)
# ============================================================

set promptfmt "\033[38;5;240m[\033[32;1m%u\033[38;5;240m@\033[36;1m%h\033[38;5;240m]\033[0m \033[34;1m%d\033[33;1m%f\033[0m "

# ============================================================
#  Dynamic Prompt — git branch + zoxide tracking
# ============================================================

cmd on-cd &{{
    # Feed zoxide
    zoxide add "$PWD" 2>/dev/null || true

    # Build git segment if inside a repo
    git_seg=""
    if git_root=$(git rev-parse --show-toplevel 2>/dev/null); then
        branch=$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null)
        dirty=$(git status --porcelain 2>/dev/null | head -1)
        indicator=""
        [ -n "$dirty" ] && indicator="*"
        git_seg="\033[38;5;240m [\033[33m${branch}${indicator}\033[38;5;240m]"
    fi

    fmt="\033[38;5;240m[\033[32;1m%u\033[38;5;240m@\033[36;1m%h\033[38;5;240m]\033[0m \033[34;1m%d\033[33;1m%f\033[0m${git_seg}"
    lf -remote "send $id set promptfmt \"$(printf '%s' "$fmt" | sed 's/\\/\\\\/g;s/"/\\"/g')\""
}}

# Run on-cd at startup too
cmd on-load &{{
    lf -remote "send $id on-cd"
}}

