#!/bin/sh

if [ -z "$1" ];then
    url="$(xclip -o 2>/dev/null)"
else
    url="$1"
fi

case "$url" in
    *mkv|*webm|*mp4|*youtube.com/watch*|*youtube.com/playlist*|*youtube.com/shorts*|*youtu.be*|*hooktube.com*|*bitchute.com*|*odysee.com*|*piped.*)
        setsid -f mpv -quiet "$url" >/dev/null 2>&1 ;;
    *png|*jpg|*jpe|*jpeg|*gif)
        nsxiv-url "$url" ;;
    *)
        [ -f "$url" ] && setsid -f "$TERMINAL" -e "$EDITOR" "$url" >/dev/null 2>&1 || setsid -f "$BROWSER" "$url" >/dev/null 2>&1 ;;
esac

