#!/bin/sh

# New вҖ” launcher-agnostic
. menu || exit 1

case "$(printf "рҹ”’ lock \
    \nрҹҡӘ leave $WM \
    \nвҷ»пёҸ renew $WM \
    \nрҹҗ» hibernate \
    \nрҹ”ғ reboot \
    \nрҹ–ҘпёҸshutdon \
    \nрҹ’Ө sleep \
    \nрҹ“ә display off" \
    | menu -l 10 -p 'Action: ')" in
	'рҹ”’ lock') slock ;;
	# "рҹҡӘ leave $WM") kill -TERM "$(wmpid)" ;;
	# "вҷ»пёҸ renew $WM") kill -HUP "$(wmpid)" ;;
	# 'рҹҗ» hibernate') slock $ctl hibernate -i ;;
	# 'рҹ’Ө sleep') slock $ctl suspend -i ;;
	'рҹ”ғ reboot') doas reboot -i ;;
	'рҹ–ҘпёҸshutdown')doas poweroff -i ;;
	'рҹ“ә display off') xset dpms force off ;;
	*) exit 1 ;;
esac
