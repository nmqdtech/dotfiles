#!/bin/sh

ID=$(xinput list | grep -Eo "TouchPad\s*id=[0-9]{2}" | grep -Eo "[0-9]{2}")
STATE=$(xinput list-props $ID | grep 'Device Enabled' | awk '{print $4}')

if [ $STATE -eq 1 ]
then
    xinput disable $ID
    notify-send "TouchPad diasbled"
else
    xinput enable $ID
    notify-send "TouchPad enabled"
fi
